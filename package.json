{
  "name": "lottery",
  "version": "1.0.0",
  "description": "两轮抽签小系统（随机/内定，Node + SQLite）",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "npx tsc && node scripts/copy-schema.js",
    "build:exe": "npm run build && pkg . --targets node18-win-x64 --output lottery-win.exe",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "db:init": "ts-node src/db/init.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "dist/db/schema.sql",
      "public/**/*"
    ]
  }
}
